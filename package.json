{
  "name": "easy-file-hider",
  "displayName": "Easy File Hider",
  "description": "Easily hide files and folders from the Explorer using a simple UI instead of manually editing settings.json",
  "author": "Fanesz",
  "publisher": "Fanesz",
  "icon": "icon.png",
  "license": "MIT",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/fanesz/easy-file-hider.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "easy-file-hider.showMenu",
        "title": "Easy File Hide: Show Menu"
      },
      {
        "command": "easy-file-hider.toggleFiles",
        "title": "Easy File Hide: Toggle Visibility"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@types/minimatch": "^5.1.2",
    "minimatch": "^10.2.4"
  }
}